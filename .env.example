# Copy this file to `.env` and fill in your Supabase project values.
# Get them from: Supabase dashboard -> Settings -> API
#   - Project URL  -> VITE_SUPABASE_URL
#   - anon public key -> VITE_SUPABASE_ANON_KEY
#
# NOTE: Supabase is OPTIONAL. The chart generator works fully offline without
# these. They are only needed for the "Save Chart" / "Saved Charts" features.
# If omitted (e.g. in Codespaces without secrets set), the app still runs —
# saving is simply disabled with a friendly message.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
